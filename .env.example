# Parser Service
PARSER_HOST=0.0.0.0
PARSER_PORT=8000
PARSER_LOG_LEVEL=INFO
PARSER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PARSER_ENABLE_TELEMETRY=true
PARSER_OTLP_ENDPOINT=

# Web App
PARSER_SERVICE_URL=http://localhost:8000

# LLM Configuration (server-side only — never exposed to browser)
# For Ollama Cloud, set baseURL to https://ollama.com/v1
# For local Ollama, use http://localhost:11434/v1
LLM_BASE_URL=https://ollama.com/v1
LLM_DEFAULT_MODEL=gemma4:31b-cloud
LLM_ALLOWLIST=gemma4:31b-cloud,llama3.2,llama3.1
LLM_API_KEY=your-ollama-api-key-here
